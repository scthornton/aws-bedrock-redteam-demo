# Copy this file to .env and fill in values. .env is gitignored.

# ---------- AWS Bedrock (required) ----------
# Bedrock API key (bearer token). Generate from the AWS console:
#   Bedrock > API Keys > Create API key
# Token starts with "ABSK..." and is ~132 chars.
AWS_BEARER_TOKEN_BEDROCK=ABSK...replace-me...

# Bedrock inference profile or model ID. The newer Sonnet/Opus 4.x models require an
# inference profile (us.* or global.*), not a bare model ID. Older claude-3-* models
# support ON_DEMAND directly. Run scripts/list-bedrock-models.sh to see what's available
# on your account.
#
# Common model IDs:
#   us.anthropic.claude-opus-4-5-20251101-v1:0      Claude Opus 4.5
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0    Claude Sonnet 4.5
#   us.anthropic.claude-haiku-4-5-20251001-v1:0     Claude Haiku 4.5
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

AWS_REGION=us-east-1

# ---------- Demo app authentication (required) ----------
# Bearer token AIRS Red Teaming will send to this app. Pick a long random string.
DEMO_API_KEY=change-me-to-a-random-string

# ---------- Prisma AIRS Runtime overlay (optional) ----------
# Set to "true" to enable the pre/post scan path. Off by default.
ENABLE_RUNTIME_SECURITY=false
# AIRS Runtime API token (x-pan-token). Required only if ENABLE_RUNTIME_SECURITY=true.
AIRS_API_KEY=
# AIRS profile to scan against. Default profile in most tenants is "chatbot".
AIRS_PROFILE=chatbot
# AIRS scan endpoint. Override only if you're on a non-default tenant region.
AIRS_API_URL=https://service.api.aisecurity.paloaltonetworks.com/v1/scan/sync/request

# ---------- App ----------
PORT=8080
# IMPORTANT: keep at 200. AIRS Red Teaming's parser scores responses by body content;
# non-2xx codes get classified as API errors instead of attack outcomes. Configurable
# only for production tuning, NOT for the demo flow.
BLOCK_STATUS_CODE=200

# Optional: app identity used in AIRS scan metadata.
# When deploying multiple instances, set a distinct name per target so AIRS
# scan logs differentiate them (e.g., aws-bedrock-redteam-opus).
APP_NAME=aws-bedrock-redteam-demo
