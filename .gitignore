# Local environment files (NEVER commit secrets)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Build / runtime artifacts
dist/
build/
*.log
logs/

# Terraform (if/when used)
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# Docker
.docker/

# Local key material (defense-in-depth — should never end up here)
*.pem
*.key
ssh_keys/
